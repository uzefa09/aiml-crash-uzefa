    "# Task 8: SQL Queries\n",
    "\n",
    "conn = sqlite3.connect(\":memory:\")\n",
    "df.to_sql(\"sales\", conn, index=False, if_exists=\"replace\")\n",
    "\n",
    "queries = [\n",
    "    (\"1. All data\", \"SELECT * FROM sales LIMIT 5\"),\n",
    "    (\"2. Total sales\", \"SELECT SUM(sales) as total FROM sales\"),\n",
    "    (\"3. By region\", \"SELECT region, SUM(sales) as total FROM sales GROUP BY region\"),\n",
    "    (\"4. North only\", \"SELECT * FROM sales WHERE region='North'\"),\n",
    "    (\"5. Top 3\", \"SELECT name, sales FROM sales ORDER BY sales DESC LIMIT 3\"),\n",
    "    (\"6. Average\", \"SELECT AVG(sales) as avg FROM sales\"),\n",
    "    (\"7. Electronics\", \"SELECT * FROM sales WHERE category='Electronics'\"),\n",
    "    (\"8. By segment\", \"SELECT segment, COUNT(*) FROM sales GROUP BY segment\"),\n",
    "    (\"9. Sales>5000\", \"SELECT name, sales FROM sales WHERE sales > 5000\"),\n",
    "    (\"10. Max sale\", \"SELECT name, MAX(sales) FROM sales\"),\n",
    "    (\"11. Min sale\", \"SELECT name, MIN(sales) FROM sales\"),\n",
    "    (\"12. Retail total\", \"SELECT SUM(sales) FROM sales WHERE segment='Retail'\"),\n",
    "    (\"13. South cats\", \"SELECT category, SUM(sales) FROM sales WHERE region='South' GROUP BY category\"),\n",
    "    (\"14. Region count\", \"SELECT region, COUNT(*) FROM sales GROUP BY region\"),\n",
    "    (\"15. By quantity\", \"SELECT name, quantity FROM sales ORDER BY quantity DESC\"),\n",
    "]\n",
    "\n",
    "for title, query in queries:\n",
    "    print(f\"\\n=== {title} ===\")\n",
    "    print(pd.read_sql_query(query, conn))"
   ]
