    "# Task 3: Test Different Train/Test Splits\n",
    "\n",
    "splits = [0.2, 0.3, 0.4]\n",
    "split_names = ['80/20', '70/30', '60/40']\n",
    "X_multi = df[['median_income', 'housing_median_age', 'total_rooms']]\n",
    "\n",
    "results = []\n",
    "for split, name in zip(splits, split_names):\n",
    "    X_tr, X_te, y_tr, y_te = train_test_split(X_multi, y, test_size=split, random_state=42)\n",
    "    m = LinearRegression()\n",
    "    m.fit(X_tr, y_tr)\n",
    "    \n",
    "    train_pred = m.predict(X_tr)\n",
    "    test_pred = m.predict(X_te)\n",
    "    \n",
    "    results.append({\n",
    "        'Split': name,\n",
    "        'Train RMSE': round(np.sqrt(mean_squared_error(y_tr, train_pred)), 2),\n",
    "        'Test RMSE': round(np.sqrt(mean_squared_error(y_te, test_pred)), 2),\n",
    "        'Test MAE': round(mean_absolute_error(y_te, test_pred), 2),\n",
    "        'Test R²': round(r2_score(y_te, test_pred), 4)\n",
    "    })\n",
    "\n",
    "df_splits = pd.DataFrame(results)\n",
    "print(df_splits)\n",
    "\n",
    "# Plot\n",
    "plt.figure(figsize=(8, 5))\n",
    "plt.plot(split_names, df_splits['Train RMSE'], 'b-o', label='Train RMSE')\n",
    "plt.plot(split_names, df_splits['Test RMSE'], 'r-o', label='Test RMSE')\n",
    "plt.title('Train vs Test RMSE across Splits')\n",
    "plt.xlabel('Split')\n",
    "plt.ylabel('RMSE')\n",
    "plt.legend()\n",
    "plt.grid(True)\n",
    "plt.show()\n",
    "\n",
    "print(\"\\n80/20 split gives most reliable test performance!\")"
   ]
