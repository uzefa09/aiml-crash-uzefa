   "source": [
    "# Step 3: Merge Tables\n",
    "\n",
    "# Merge orders with items\n",
    "df = pd.merge(orders_clean, items, on='order_id', how='inner')\n",
    "\n",
    "# Merge with products\n",
    "df = pd.merge(df, products[['product_id', 'product_category_name']], on='product_id', how='left')\n",
    "\n",
    "# Merge with customers\n",
    "df = pd.merge(df, customers[['customer_id', 'customer_state', 'customer_city']], on='customer_id', how='left')\n",
    "\n",
    "# Calculate total revenue per order item\n",
    "df['revenue'] = df['price'] + df['freight_value']\n",
    "\n",
    "print(\"Final merged shape:\", df.shape)\n",
    "print(\"Columns:\", df.columns.tolist())\n",
    "print(\"\\nSample data:\")\n",
    "df.head(3)"
